# ─────────────────────────────────────────────
# VortexRAG — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── AI PROVIDERS (FREE TIER SETUP) ──────────────
# 1. Get free Llama 3 API key from: https://console.groq.com/
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama3-70b-8192

# 2. Get free Embeddings API key (50M tokens) from: https://dash.voyageai.com/
VOYAGE_API_KEY=pa-your-voyage-key-here
EMBEDDING_MODEL=voyage-code-2
EMBEDDING_DIMENSION=1536

# Optional: OpenAI (if you want to switch back later)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ── Qdrant ────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=vortex_codebase

# ── Neo4j ─────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=vortexpassword

# ── Redis ─────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=vortexredis
SEMANTIC_CACHE_TTL=3600           # Cache TTL in seconds (1 hour)
SEMANTIC_CACHE_THRESHOLD=0.92     # Cosine similarity threshold

# ── FastAPI ───────────────────────────────────
SECRET_KEY=change_me_to_a_random_256_bit_secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ── Langfuse (Observability) ──────────────────
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_HOST=https://cloud.langfuse.com

# ── GitHub App (Phase 5) ──────────────────────
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=./github_app.pem
GITHUB_WEBHOOK_SECRET=

# ── General ───────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
